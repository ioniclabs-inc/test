function switchTab(tab) {
  ['study','quiz','flash','cheat'].forEach(t => {
    document.getElementById('sec-' + t).classList.toggle('hidden', t !== tab);
    document.getElementById('tab-' + t).classList.toggle('active', t === tab);
  });
  state.activeTab = tab;
}

