function buildStudyFilters() {
  const wrap = document.getElementById('study-filters');
  const allPill = document.createElement('div');
  allPill.className = 'pill active';
  allPill.textContent = 'All';
  allPill.onclick = () => setStudyCat('all');
  allPill.id = 'spill-all';
  wrap.appendChild(allPill);
  Object.keys(CATS).forEach(cat => {
    const p = document.createElement('div');
    p.className = 'pill';
    p.textContent = cat;
    p.id = 'spill-' + cat;
    p.onclick = () => setStudyCat(cat);
    wrap.appendChild(p);
  });
}

function setStudyCat(cat) {
  state.studyCat = cat;
  document.querySelectorAll('.pill').forEach(p => p.classList.remove('active'));
  document.getElementById('spill-' + (cat === 'all' ? 'all' : cat)).classList.add('active');
  buildStudyList();
}

function filterStudy() {
  state.studySearch = document.getElementById('study-search').value.toLowerCase();
  buildStudyList();
}

function buildStudyList() {
  const list = document.getElementById('qa-list');
  const empty = document.getElementById('study-empty');
  list.innerHTML = '';
  const filtered = Q.filter(q => {
    const catMatch = state.studyCat === 'all' || q.cat === state.studyCat;
    const searchMatch = !state.studySearch ||
      q.q.toLowerCase().includes(state.studySearch) ||
      q.opts[q.ans].toLowerCase().includes(state.studySearch) ||
      q.cat.toLowerCase().includes(state.studySearch);
    return catMatch && searchMatch;
  });
  document.getElementById('study-count').textContent = filtered.length + ' question' + (filtered.length !== 1 ? 's' : '');
  if (filtered.length === 0) {
    empty.classList.remove('hidden');
    return;
  }
  empty.classList.add('hidden');
  filtered.forEach(q => {
    const catStyle = CATS[q.cat];
    const card = document.createElement('div');
    card.className = 'qa-card';
    card.id = 'qac-' + q.id;
    const optsHtml = q.opts.map((opt, i) => {
      const isCorrect = i === q.ans;
      return `<div class="option-item ${isCorrect ? 'correct' : ''}">
        <span class="option-icon">${isCorrect ? '✓' : '○'}</span>
        <span>${opt}</span>
      </div>`;
    }).join('');
    card.innerHTML = `
      <div class="qa-header" onclick="toggleCard(${q.id})">
        <div class="qa-num">Q${q.id}</div>
        <div class="qa-question">${q.q}</div>
        <div class="qa-right">
          <span class="cat-badge" style="color:${catStyle.color};border-color:${catStyle.color};background:${catStyle.bg};">${q.cat}</span>
          <span class="qa-chevron">▾</span>
        </div>
      </div>
      <div class="qa-body">
        <div class="options-list">${optsHtml}</div>
        <div class="explanation-box">
          <div class="explanation-label">Explanation</div>
          <div class="explanation-text">${q.exp}</div>
        </div>
      </div>`;
    list.appendChild(card);
  });
}

function toggleCard(id) {
  const card = document.getElementById('qac-' + id);
  card.classList.toggle('open');
}

