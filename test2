  const sel = document.getElementById('quiz-cat-dropdown');
  sel.innerHTML = '<option value="all">All Categories</option>';
  Object.keys(CATS).forEach(cat => {
    const o = document.createElement('option');
    o.value = cat;
    o.textContent = cat + ' (' + Q.filter(q => q.cat === cat).length + ')';
    sel.appendChild(o);
  });
}

function setQuizCount(n) {
  quizCount = n;
  ['10','25','49','cat'].forEach(v => {
    document.getElementById('qc-' + v).classList.remove('selected');
  });
  document.getElementById('qc-' + n).classList.add('selected');
  const catSel = document.getElementById('quiz-cat-select');
  catSel.classList.toggle('hidden', n !== 'cat');
}

function startQuiz() {
  let pool = [...Q];
  if (quizCount === 'cat') {
    const cat = document.getElementById('quiz-cat-dropdown').value;
    if (cat !== 'all') pool = pool.filter(q => q.cat === cat);
  }
  pool = shuffleArr(pool);
  const count = quizCount === 'cat' ? pool.length : Math.min(quizCount, pool.length);
  state.quiz.questions = pool.slice(0, count);
  state.quiz.current = 0;
  state.quiz.score = 0;
  state.quiz.wrongAnswers = [];
  document.getElementById('quiz-setup').classList.add('hidden');
  document.getElementById('quiz-results').classList.add('hidden');
  document.getElementById('quiz-active').classList.remove('hidden');
  renderQuizQuestion();
}

function renderQuizQuestion() {
  const qz = state.quiz;
  const q = qz.questions[qz.current];
  const total = qz.questions.length;
  const progress = ((qz.current) / total) * 100;
  document.getElementById('quiz-pos').textContent = `Question ${qz.current + 1} of ${total}`;
  document.getElementById('quiz-score-live').textContent = `Score: ${qz.score}/${qz.current}`;
  document.getElementById('quiz-prog').style.width = progress + '%';
  const catStyle = CATS[q.cat];
  document.getElementById('quiz-q-cat').innerHTML = `<span style="color:${catStyle.color};font-size:11px;letter-spacing:0.15em;text-transform:uppercase;">● ${q.cat}</span>`;
  document.getElementById('quiz-q-text').textContent = q.q;
  const letters = ['A', 'B', 'C', 'D'];
  const answersDiv = document.getElementById('quiz-answers');
  answersDiv.innerHTML = '';
  const shuffledOpts = q.opts.map((opt, i) => ({ opt, origIdx: i }));
  q._shuffled = shuffledOpts;
  shuffledOpts.forEach((item, i) => {
    const btn = document.createElement('button');
    btn.className = 'quiz-answer';
    btn.dataset.letter = letters[i];
    btn.dataset.origIdx = item.origIdx;
    btn.textContent = item.opt;
    btn.onclick = () => selectAnswer(btn, item.origIdx);
    answersDiv.appendChild(btn);
  });
  document.getElementById('quiz-expl').classList.remove('show');
  document.getElementById('quiz-feedback-msg').textContent = '';
  document.getElementById('quiz-next-btn').disabled = true;
  qz.answered = false;
}

function selectAnswer(btn, origIdx) {
  const qz = state.quiz;
  if (qz.answered) return;
  qz.answered = true;
  qz.selected = origIdx;
  const q = qz.questions[qz.current];
  const isCorrect = origIdx === q.ans;
  if (isCorrect) qz.score++;
  document.querySelectorAll('.quiz-answer').forEach(b => {
    b.disabled = true;
    const bIdx = parseInt(b.dataset.origIdx);
    if (bIdx === q.ans) b.classList.add('correct-a');
    else if (b === btn && !isCorrect) b.classList.add('wrong-a');
  });
  const expl = document.getElementById('quiz-expl');
  expl.innerHTML = q.exp;
  expl.classList.add('show');
  const msg = document.getElementById('quiz-feedback-msg');
  if (isCorrect) {
    msg.style.color = 'var(--green)';
    msg.textContent = '✓ Correct!';
  } else {
    msg.style.color = 'var(--red)';
    msg.textContent = '✗ Incorrect';
    qz.wrongAnswers.push({ q: q.q, yourAns: q.opts[origIdx], correctAns: q.opts[q.ans] });
  }
  document.getElementById('quiz-next-btn').disabled = false;
  document.getElementById('quiz-score-live').textContent = `Score: ${qz.score}/${qz.current + 1}`;
}

function nextQuestion() {
  const qz = state.quiz;
  qz.current++;
  if (qz.current >= qz.questions.length) {
    showResults();
  } else {
    renderQuizQuestion();
  }
}

function showResults() {
  document.getElementById('quiz-active').classList.add('hidden');
  document.getElementById('quiz-results').classList.remove('hidden');
  const qz = state.quiz;
  const pct = Math.round((qz.score / qz.questions.length) * 100);
  document.getElementById('results-pct').textContent = pct + '%';
  document.getElementById('results-frac').textContent = qz.score + '/' + qz.questions.length;
  const circumference = 2 * Math.PI * 60;
  const fill = document.getElementById('results-ring-fill');
  const offset = circumference - (pct / 100) * circumference;
  const color = pct >= 80 ? 'var(--green)' : pct >= 60 ? 'var(--amber)' : 'var(--red)';
  fill.style.stroke = color;
  document.getElementById('results-pct').style.color = color;
  setTimeout(() => { fill.style.strokeDashoffset = offset; }, 100);
  let msg, sub;
  if (pct === 100) { msg = '🏆 Perfect Score!'; sub = 'You mastered every single question.'; }
  else if (pct >= 80) { msg = '🎉 Excellent!'; sub = 'You\'re well-prepared for the certification.'; }
  else if (pct >= 60) { msg = '📈 Good Progress'; sub = 'Review the missed questions and try again.'; }
  else { msg = '📚 Keep Studying'; sub = 'Focus on the categories where you missed questions.'; }
  document.getElementById('results-msg').textContent = msg;
  document.getElementById('results-sub').textContent = sub;
  const wrongReview = document.getElementById('wrong-review');
  if (qz.wrongAnswers.length > 0) {
    wrongReview.innerHTML = `<div class="wrong-review-title">✗ Missed Questions (${qz.wrongAnswers.length})</div>` +
      qz.wrongAnswers.map(w => `
        <div class="wrong-card">
          <div class="wrong-card-q">${w.q}</div>
          <div class="wrong-card-yours">✗ Your answer: ${w.yourAns}</div>
          <div class="wrong-card-correct">✓ Correct: ${w.correctAns}</div>
        </div>`).join('');
  } else {
    wrongReview.innerHTML = '<div style="text-align:center;color:var(--green);font-family:var(--mono);font-size:13px;padding:20px 0;">🎯 Zero mistakes — flawless!</div>';
  }
}

function retryQuiz() {
  startQuiz();
}

function showSetup() {
  document.getElementById('quiz-active').classList.add('hidden');
  document.getElementById('quiz-results').classList.add('hidden');
  document.getElementById('quiz-setup').classList.remove('hidden');
}

