<style>
:root {
--bg: #070b14;
--surface: #0d1421;
--card: #111827;
--card2: #162033;
--border: #1e2d45;
--border2: #2a3f5f;
--blue: #3b82f6;
--blue-dim: #1d4ed8;
--blue-glow: rgba(59,130,246,0.15);
--green: #10b981;
--green-glow: rgba(16,185,129,0.15);
--amber: #f59e0b;
--red: #ef4444;
--cyan: #06b6d4;
--purple: #8b5cf6;
--text: #e2e8f0;
--text2: #94a3b8;
--text3: #64748b;
--mono: 'Space Mono', monospace;
--head: 'Syne', sans-serif;
--body: 'DM Sans', sans-serif;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
background: var(--bg);
color: var(--text);
font-family: var(--body);
font-size: 15px;
min-height: 100vh;
line-height: 1.6;
}

.hero {
background: linear-gradient(135deg, #0d1421 0%, #0a1628 50%, #070b14 100%);
border-bottom: 1px solid var(--border);
padding: 48px 40px 36px;
position: relative;
overflow: hidden;
}
.hero::before {
content: '';
position: absolute;
top: -80px; right: -80px;
width: 400px; height: 400px;
background: radial-gradient(circle, rgba(59,130,246,0.08) 0%, transparent 70%);
pointer-events: none;
}
.hero::after {
content: '';
position: absolute;
bottom: 0; left: 0; right: 0;
height: 1px;
background: linear-gradient(90deg, transparent, var(--blue), transparent);
}
.hero-label {
font-family: var(--mono);
font-size: 11px;
color: var(--blue);
letter-spacing: 0.2em;
text-transform: uppercase;
margin-bottom: 12px;
display: flex;
align-items: center;
gap: 8px;
}
.hero-label::before {
content: ''; display: block;
width: 24px; height: 1px;
background: var(--blue);
}
.hero h1 {
font-family: var(--head);
font-size: clamp(28px, 4vw, 48px);
font-weight: 800;
letter-spacing: -0.02em;
line-height: 1.1;
background: linear-gradient(135deg, #fff 0%, #94a3b8 100%);
-webkit-background-clip: text;
-webkit-text-fill-color: transparent;
background-clip: text;
margin-bottom: 8px;
}
.hero-sub {
color: var(--text2);
font-size: 15px;
margin-bottom: 32px;
}
.stat-grid {
display: grid;
grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
gap: 12px;
max-width: 640px;
}
.stat-card {
background: rgba(255,255,255,0.03);
border: 1px solid var(--border);
border-radius: 10px;
padding: 16px 20px;
position: relative;
overflow: hidden;
}
.stat-card::before {
content: '';
position: absolute;
top: 0; left: 0; right: 0;
height: 2px;
}
.stat-card.blue::before { background: var(--blue); }
.stat-card.green::before { background: var(--green); }
.stat-card.amber::before { background: var(--amber); }
.stat-card.purple::before { background: var(--purple); }
.stat-num {
font-family: var(--head);
font-size: 28px;
font-weight: 800;
line-height: 1;
margin-bottom: 4px;
}
.stat-card.blue .stat-num { color: var(--blue); }
.stat-card.green .stat-num { color: var(--green); }
.stat-card.amber .stat-num { color: var(--amber); }
.stat-card.purple .stat-num { color: var(--purple); }
.stat-label {
font-size: 11px;
color: var(--text3);
font-family: var(--mono);
text-transform: uppercase;
letter-spacing: 0.1em;
}

.nav-wrap {
background: var(--surface);
border-bottom: 1px solid var(--border);
position: sticky;
top: 0;
z-index: 100;
padding: 0 40px;
}
.nav-tabs {
display: flex;
gap: 0;
overflow-x: auto;
scrollbar-width: none;
}
.nav-tabs::-webkit-scrollbar { display: none; }
.nav-tab {
padding: 16px 24px;
font-size: 13px;
font-weight: 500;
font-family: var(--mono);
color: var(--text3);
cursor: pointer;
border-bottom: 2px solid transparent;
white-space: nowrap;
transition: all 0.2s;
user-select: none;
letter-spacing: 0.05em;
text-transform: uppercase;
}
.nav-tab:hover { color: var(--text2); }
.nav-tab.active { color: var(--blue); border-bottom-color: var(--blue); }

.main { max-width: 1100px; margin: 0 auto; padding: 32px 40px 80px; }

.section-head {
display: flex;
align-items: center;
gap: 16px;
margin-bottom: 28px;
flex-wrap: wrap;
}
.section-title {
font-family: var(--head);
font-size: 22px;
font-weight: 700;
}
.badge-count {
background: var(--blue-glow);
color: var(--blue);
border: 1px solid rgba(59,130,246,0.3);
border-radius: 20px;
padding: 2px 12px;
font-size: 12px;
font-family: var(--mono);
}

.controls {
display: flex;
gap: 12px;
margin-bottom: 24px;
flex-wrap: wrap;
}
.search-box {
flex: 1;
min-width: 200px;
background: var(--card);
border: 1px solid var(--border);
border-radius: 8px;
padding: 10px 16px 10px 40px;
color: var(--text);
font-size: 14px;
font-family: var(--body);
outline: none;
transition: border-color 0.2s;
position: relative;
}
.search-box:focus { border-color: var(--blue); }
.search-wrap { position: relative; flex: 1; min-width: 200px; }
.search-icon {
position: absolute;
left: 12px; top: 50%;
transform: translateY(-50%);
color: var(--text3);
pointer-events: none;
font-size: 16px;
}
.filter-pills {
display: flex;
gap: 8px;
flex-wrap: wrap;
}
.pill {
padding: 6px 14px;
border-radius: 20px;
font-size: 12px;
font-family: var(--mono);
cursor: pointer;
border: 1px solid var(--border);
color: var(--text3);
background: var(--card);
transition: all 0.2s;
white-space: nowrap;
}
.pill:hover { border-color: var(--border2); color: var(--text2); }
.pill.active { border-color: var(--blue); color: var(--blue); background: var(--blue-glow); }

.qa-list { display: flex; flex-direction: column; gap: 10px; }
.qa-card {
background: var(--card);
border: 1px solid var(--border);
border-radius: 12px;
overflow: hidden;
transition: border-color 0.2s;
}
.qa-card:hover { border-color: var(--border2); }
.qa-card.open { border-color: var(--blue); }
.qa-header {
padding: 18px 20px;
cursor: pointer;
display: flex;
align-items: flex-start;
gap: 14px;
}
.qa-num {
font-family: var(--mono);
font-size: 11px;
color: var(--blue);
min-width: 28px;
padding-top: 2px;
}
.qa-question {
flex: 1;
font-size: 14px;
font-weight: 500;
color: var(--text);
line-height: 1.5;
}
.qa-right {
display: flex;
align-items: center;
gap: 10px;
flex-shrink: 0;
}
.cat-badge {
font-size: 10px;
font-family: var(--mono);
padding: 3px 10px;
border-radius: 20px;
border: 1px solid;
white-space: nowrap;
}
.qa-chevron {
color: var(--text3);
font-size: 18px;
transition: transform 0.25s;
line-height: 1;
}
.qa-card.open .qa-chevron { transform: rotate(180deg); }
.qa-body {
display: none;
padding: 0 20px 20px 62px;
border-top: 1px solid var(--border);
margin-top: 0;
}
.qa-card.open .qa-body { display: block; }
.options-list { margin: 16px 0 0; display: flex; flex-direction: column; gap: 8px; }
.option-item {
display: flex;
align-items: flex-start;
gap: 10px;
padding: 10px 14px;
border-radius: 8px;
font-size: 13px;
line-height: 1.5;
border: 1px solid transparent;
color: var(--text3);
background: rgba(255,255,255,0.02);
}
.option-item.correct {
background: var(--green-glow);
border-color: rgba(16,185,129,0.3);
color: var(--text);
}
.option-icon {
font-size: 14px;
flex-shrink: 0;
margin-top: 1px;
}
.correct .option-icon { color: var(--green); }
.explanation-box {
margin-top: 16px;
padding: 16px;
background: rgba(59,130,246,0.05);
border-left: 3px solid var(--blue);
border-radius: 0 8px 8px 0;
}
.explanation-label {
font-family: var(--mono);
