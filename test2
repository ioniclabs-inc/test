function populateFCCatFilter() {
  const sel = document.getElementById('fc-cat-filter');
  Object.keys(CATS).forEach(cat => {
    const o = document.createElement('option');
    o.value = cat;
    o.textContent = cat;
    sel.appendChild(o);
  });
}

function buildFlashcards() {
  resetFCDeck();
}

function resetFCDeck() {
  const fc = state.fc;
  const cat = fc.filterCat;
  let pool = cat === 'all' ? [...Q] : Q.filter(q => q.cat === cat);
  if (fc.reviewMode) pool = pool.filter(q => fc.review.has(q.id));
  fc.deck = pool;
  fc.current = 0;
  fc.flipped = false;
  if (!fc.reviewMode) { fc.known = new Set(); fc.review = new Set(); fc.seen = new Set(); }
  renderFlashcard();
  updateFCStats();
}

function fcFilter() {
  state.fc.filterCat = document.getElementById('fc-cat-filter').value;
  state.fc.reviewMode = false;
  resetFCDeck();
}

function fcShuffle() {
  state.fc.deck = shuffleArr([...state.fc.deck]);
  state.fc.current = 0;
  state.fc.flipped = false;
  renderFlashcard();
}

function fcReviewOnly() {
  state.fc.reviewMode = !state.fc.reviewMode;
  const fc = state.fc;
  if (fc.reviewMode) {
    const cat = fc.filterCat;
    let pool = cat === 'all' ? [...Q] : Q.filter(q => q.cat === cat);
    fc.deck = pool.filter(q => fc.review.has(q.id));
    if (fc.deck.length === 0) {
      fc.reviewMode = false;
      fc.deck = cat === 'all' ? [...Q] : pool;
      alert('No cards marked for review yet!');
    }
  } else {
    const cat = fc.filterCat;
    fc.deck = cat === 'all' ? [...Q] : Q.filter(q => q.cat === cat);
  }
  fc.current = 0;
  fc.flipped = false;
  renderFlashcard();
  updateFCStats();
  document.getElementById('fc-review-btn').textContent = `↺ Review Only (${fc.review.size})`;
}

function fcReset() {
  state.fc.known = new Set();
  state.fc.review = new Set();
  state.fc.seen = new Set();
  state.fc.reviewMode = false;
  resetFCDeck();
  document.getElementById('fc-review-btn').textContent = `↺ Review Only (0)`;
}

function flipCard() {
  const fc = state.fc;
  fc.flipped = !fc.flipped;
  document.getElementById('fc-inner').classList.toggle('flipped', fc.flipped);
  const actBtns = document.getElementById('fc-action-btns');
  actBtns.style.display = fc.flipped ? 'flex' : 'none';
  if (fc.deck.length > 0) {
    fc.seen.add(fc.deck[fc.current].id);
    updateFCStats();
  }
}

function fcNav(dir) {
  const fc = state.fc;
  if (fc.deck.length === 0) return;
  fc.current = (fc.current + dir + fc.deck.length) % fc.deck.length;
  fc.flipped = false;
  document.getElementById('fc-inner').classList.remove('flipped');
  document.getElementById('fc-action-btns').style.display = 'none';
  renderFlashcard();
}

function fcMark(type) {
  const fc = state.fc;
  if (fc.deck.length === 0) return;
  const id = fc.deck[fc.current].id;
  if (type === 'known') {
    fc.known.add(id);
    fc.review.delete(id);
  } else {
    fc.review.add(id);
    fc.known.delete(id);
  }
  updateFCStats();
  document.getElementById('fc-review-btn').textContent = `↺ Review Only (${fc.review.size})`;
  fcNav(1);
}

function renderFlashcard() {
  const fc = state.fc;
  if (fc.deck.length === 0) {
    document.getElementById('fc-q-text').textContent = 'No cards in this set.';
    document.getElementById('fc-ans-text').textContent = '—';
    document.getElementById('fc-exp-text').textContent = '';
    document.getElementById('fc-cur').textContent = '0';
    document.getElementById('fc-total').textContent = '0';
    document.getElementById('fc-count-badge').textContent = '0 cards';
    return;
  }
  const q = fc.deck[fc.current];
  const catStyle = CATS[q.cat];
  document.getElementById('fc-q-text').textContent = q.q;
  document.getElementById('fc-ans-text').textContent = q.opts[q.ans];
  document.getElementById('fc-exp-text').innerHTML = q.exp.replace(/<[^>]*>/g, '').slice(0, 180) + (q.exp.length > 180 ? '...' : '');
  document.getElementById('fc-cur').textContent = fc.current + 1;
  document.getElementById('fc-total').textContent = fc.deck.length;
  document.getElementById('fc-count-badge').textContent = fc.deck.length + ' cards';
  document.getElementById('fc-front-cat').textContent = q.cat;
  document.getElementById('fc-front-cat').style.color = catStyle.color;
  document.getElementById('fc-front-cat').style.borderColor = catStyle.color;
  document.getElementById('fc-front-cat').style.background = catStyle.bg;
}

function updateFCStats() {
  const fc = state.fc;
  document.getElementById('fc-known-count').textContent = fc.known.size;
  document.getElementById('fc-review-count').textContent = fc.review.size;
  const unseen = fc.deck.filter(q => !fc.seen.has(q.id)).length;
  document.getElementById('fc-unseen-count').textContent = unseen;
}

// ══════════════════════════════════════════════════
//  CHEAT SHEET
// ══════════════════════════════════════════════════
function buildCheatSheet() {
  const grid = document.getElementById('cheat-grid');
  CHEAT.forEach(sheet => {
    const card = document.createElement('div');
    card.className = 'cheat-card';
    card.innerHTML = `
      <div class="cheat-card-accent" style="background:${sheet.accent};"></div>
      <h3 style="color:${sheet.accent};">${sheet.title}</h3>
      ${sheet.html}`;
    grid.appendChild(card);
  });
}

// ══════════════════════════════════════════════════
//  UTILITY
// ══════════════════════════════════════════════════
function shuffleArr(arr) {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}
